<!DOCTYPE html>
<html lang="ru" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title || 'Фото Хостинг' %></title>
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="navbar bg-base-100 border-b">
      <div class="container mx-auto px-4 gap-2">
        <a href="/" class="btn btn-ghost text-xl">Фото Хостинг</a>
        <nav class="ml-auto flex gap-2">
          <a class="btn btn-sm" href="/">Лента</a>
          <a class="btn btn-sm btn-primary" href="/upload">Загрузить</a>
        </nav>
      </div>
    </header>
    <main class="container mx-auto px-4 py-6 flex-1">
      <%- body %>
    </main>
    <footer class="footer footer-center p-4 bg-base-200 text-base-content">
      <aside>
        <p>© <%= new Date().getFullYear() %> Фото Хостинг</p>
      </aside>
    </footer>
  </body>
</html>